NEXT_PUBLIC_RERA=P02400006761
NEXT_PUBLIC_API_URL=http://localhost:3000

# ── LLM (Google Gemini) ─────────────────────────────────
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── MongoDB Atlas ───────────────────────────────────────
# Atlas → cluster → Connect → Drivers → copy SRV string
# Replace <password> with the DB user's actual password
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=asbl_loft

# ── Zoho CRM ingest ─────────────────────────────────────
CRM_INGEST_URL=https://asbl-crm-api.vercel.app/api/ingest/website
# CRM_API_KEY=only_if_zoho_requires_bearer_token

# ── Admin token for /api/media/upload ───────────────────
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=your_random_hex_admin_token
